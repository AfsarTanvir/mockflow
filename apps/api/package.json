{
  "name": "@mockflow/api",
  "version": "0.1.0",
  "description": "MockFlow API - AdonisJS backend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --import tsx/esm ace serve --watch",
    "build": "node --import tsx/esm ace build",
    "start": "node build/bin/server.js",
    "migration:run": "node --import tsx/esm ace migration:run",
    "migration:rollback": "node --import tsx/esm ace migration:rollback",
    "migration:fresh": "node --import tsx/esm ace migration:fresh --seed",
    "db:seed": "node --import tsx/esm ace db:seed",
    "lint": "eslint . --ext=.ts",
    "format": "prettier --write \"**/*.ts\""
  },
  "imports": {
    "#app/*": "./app/*.js",
    "#config/*": "./config/*.js",
    "#database/*": "./database/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#start/*": "./start/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.2",
    "@adonisjs/eslint-config": "^3.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^8.56.0",
    "hot-hook": "^0.3.0",
    "prettier": "^3.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/hash": "^7.0.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/tsconfig": "^2.0.0",
    "@faker-js/faker": "^8.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@vinejs/vine": "^2.1.0",
    "bullmq": "^5.1.0",
    "luxon": "^3.4.4",
    "mailtrap": "^4.5.1",
    "nodemailer": "^8.0.7",
    "path-to-regexp": "^6.2.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "youch": "^4.1.1"
  }
}
