
# Platform master-agency company slug; its active admin+ members become super-admins.
# Leave unset to disable the /api/admin console.
MASTER_COMPANY_SLUG=
MASTER_COMPANY_MIN_ROLE=admin

# Redis cache. Without REDIS_HOST the app still runs — it just degrades to
# DB-only (no caching). CACHE_ENABLED=false is a global kill switch. TTLs in seconds.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_ENABLED=true
CACHE_TTL_MOCK=300
CACHE_TTL_ENTITY=600
